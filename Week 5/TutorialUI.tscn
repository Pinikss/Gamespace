[sub_resource type="GDScript" id="GDScript_n2gk8"]
script/source = "extends CanvasLayer

# Menghubungkan node UI (Pastikan nama node sesuai dengan struktur scene kamu)
@onready var control_ui = $TutorialOverlay
@onready var title = $TutorialOverlay/InfoPanel/VBoxContainer/TitleLabel
@onready var label_instruksi = $TutorialOverlay/InfoPanel/VBoxContainer/InstructionLabel
@onready var tombol_lanjut = $TutorialOverlay/InfoPanel/VBoxContainer/Button

var tutorial_step = 0
var tutorial_4_done = false
var tutorial_5_done = false

func _ready():
	# Sembunyikan UI di awal game
	control_ui.hide()
	# Mulai tutorial pertama setelah jeda singkat
	await get_tree().create_timer(1.0).timeout
	start_step_1()

# --- MEKANISME DASAR ---

func show_overlay(teks: String, judul: String, show_button: bool = false):
	label_instruksi.text = teks
	title.text = judul
	tombol_lanjut.visible = show_button
	control_ui.show()

func _on_continue_button_pressed():
	control_ui.hide()
	get_tree().paused = false # Melanjutkan game jika sebelumnya pause

# --- TUTORIAL 1, 2, 3 (Berurutan) ---

func start_step_1():
	tutorial_step = 1
	show_overlay(\"Gunakan tombol A dan D untuk bergerak ke Kanan dan Kiri\", \"Movement\")
	# Catatan: Pemain tetap bisa bergerak. Script di Tank akan memanggil 'complete_step'

func start_step_2():
	tutorial_step = 2
	show_overlay(\"Gunakan tombol W dan S untuk mengarahkan Moncong Tank\", \"Aim\")

func start_step_3():
	tutorial_step = 3
	show_overlay(\"Gunakan klik kiri untuk Menembak!\", \"Shoot\")

# Fungsi ini dipanggil dari script Tank/Player
func complete_step(step_id: int):
	if tutorial_step == step_id:
		control_ui.hide()
		tutorial_step = 0 # Reset sementara
		
		# Jeda sebelum lanjut ke tutorial berikutnya agar tidak menumpuk
		await get_tree().create_timer(1.5).timeout
		
		if step_id == 1: start_step_2()
		elif step_id == 2: start_step_3()


# Dipanggil oleh script Musuh (Tutorial 4)
func trigger_enemy_tutorial():
	if not tutorial_4_done:
		get_tree().paused = true # Berhentikan dunia
		show_overlay(\"AWAS! Itu Musuh Grenadier. Dia bisa melempar granat dari jauh!\", \"Granadier\", true)
		tutorial_4_done = true

# Dipanggil oleh script Granat (Tutorial 5)
func trigger_grenade_tutorial():
	if not tutorial_5_done:
		get_tree().paused = true # Berhentikan dunia
		show_overlay(\"Lihat! Granat melambung tinggi. Perhatikan arah jatuhnya!\", \"Granade\", true)
		tutorial_5_done = true
		
func finish_tutorial():
	control_ui.hide()          # Sembunyikan semua UI tutorial
	get_tree().paused = false  # Jalankan kembali waktu game yang berhenti


func _on_button_pressed() -> void:
	finish_tutorial()
"

