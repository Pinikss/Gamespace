[sub_resource type="GDScript" id="GDScript_1ealj"]
script/source = "extends CharacterBody2D

@export var speed = 200.0
@export var turret_speed = 1.0
@export var bullet_scene: PackedScene

@onready var sprite_container = $Container
@onready var turret_pivot = $Container/Moncong
@onready var muzzle = $Container/Moncong/Muzzle
@onready var shoot_timer = $Container/ShootTimer

var facing_direction = 1
var recoil = 100

func _physics_process(delta):
	
	var move_input = Input.get_axis(\"left\", \"right\")
	if not is_on_floor():
		velocity.y += 980 * delta
	else:
		velocity.y = 0
	
	if facing_direction:
		velocity.x = lerp(velocity.x, move_input * speed, 0.01)
		move_and_slide()


	if move_input != 0:
		facing_direction = sign(move_input)
		sprite_container.scale.x = facing_direction


	var turret_input = 0
	if Input.is_action_pressed(\"up\"):
		turret_input -= 1
	if Input.is_action_pressed(\"down\"):
		turret_input += 1
	
	turret_pivot.rotation = clamp(turret_pivot.rotation + (turret_input * turret_speed * delta), deg_to_rad(-45), deg_to_rad(10))


	if Input.is_action_just_pressed(\"shoot\") and shoot_timer.is_stopped():
		shoot()
		shoot_timer.start()

func shoot():
	var b = bullet_scene.instantiate()
	# Gunakan global_position dan global_rotation agar peluru meluncur dengan benar
	b.global_position = muzzle.global_position
	b.global_rotation = muzzle.global_rotation
	get_tree().current_scene.add_child(b)
	
	var direction = (global_position - muzzle.global_position).normalized()
	velocity += direction * recoil
"

