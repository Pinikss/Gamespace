[sub_resource type="GDScript" id="GDScript_uuvio"]
script/source = "extends CharacterBody2D

@export var grenade_scene: PackedScene
@export var throw_arc: float = -100.0
@export var movement_speed: float = 75.0
@export var stopping_distance: float = 200.0 
@export var detection_range: float = 500.0
@export var attack_range_max: float = 400.0 # Jarak maksimal boleh melempar
@export var attack_range_min: float = 200.0 # Jarak minimal (agar tidak meledak sendiri)
@export var attack_pause_time: float = 0.8

@onready var muzzle = $Muzzle
@onready var timer = $Timer
@onready var nav_agent = $NavigationAgent2D

var is_attacking: bool = false
var gravity = 980
var player: CharacterBody2D = null


func _physics_process(delta):
	if not is_on_floor():
		velocity.y += gravity * delta
	
	if not player:
		var players = get_tree().get_nodes_in_group(\"Player\")
		if players.size() > 0: player = players[0]
	
	if player and not is_attacking:
		var dist = global_position.distance_to(player.global_position)
		
		if dist <= detection_range:
			if dist < attack_range_min:
				# MEKANISME MUNDUR: Menjauh dari player
				var retreat_dir = (global_position - player.global_position).normalized()
				velocity.x = retreat_dir.x * movement_speed
				$Sprite2D.flip_h = player.global_position.x > global_position.x
			elif dist > stopping_distance:
				# MENDEKATI: Kejar player
				move_towards_player()
			else:
				# DIAM: Di jarak ideal
				velocity.x = move_toward(velocity.x, 0, movement_speed)
				$Sprite2D.flip_h = player.global_position.x > global_position.x
			
			var in_attack_zone = dist <= attack_range_max and dist >= attack_range_min
			
			if in_attack_zone and timer.is_stopped():
				start_attack_sequence()
		else:
			velocity.x = move_toward(velocity.x, 0, movement_speed)
	
	elif is_attacking:
		velocity.x = move_toward(velocity.x, 0, movement_speed)

	move_and_slide()

func start_attack_sequence():
	is_attacking = true
	$Sprite2D.flip_h = player.global_position.x > global_position.x
	
	await get_tree().create_timer(0.2).timeout
	throw_grenade()
	timer.start(2.5)
	
	await get_tree().create_timer(attack_pause_time).timeout
	is_attacking = false

func move_towards_player():
	nav_agent.target_position = player.global_position
	if not nav_agent.is_navigation_finished():
		var next_path_pos = nav_agent.get_next_path_position()
		var direction = (next_path_pos - global_position).normalized()
		velocity.x = direction.x * movement_speed
		if velocity.x != 0:
			$Sprite2D.flip_h = velocity.x > 0

func throw_grenade():
	var g = grenade_scene.instantiate()
	g.add_collision_exception_with(self) 
	
	get_parent().add_child(g)
	g.global_position = muzzle.global_position
	
	var launch_velocity = calculate_arc_velocity(muzzle.global_position, player.global_position, throw_arc)
	g.launch(launch_velocity)

func calculate_arc_velocity(source: Vector2, target: Vector2, arc_height: float):
	var g_gravity = ProjectSettings.get_setting(\"physics/2d/default_gravity\")
	var diff_x = target.x - source.x
	var diff_y = target.y - source.y
	var vel_y = sqrt(abs(2 * g_gravity * abs(arc_height))) * -1
	var time_up = vel_y / -g_gravity
	var time_down = sqrt(max(0, 2 * (diff_y - arc_height) / g_gravity))
	var total_time = time_up + time_down
	var vel_x = (diff_x / max(0.01, total_time)) / 1.5
	return Vector2(vel_x, vel_y)
"

