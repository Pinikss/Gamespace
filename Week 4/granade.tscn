[sub_resource type="GDScript" id="GDScript_4ggue"]
script/source = "extends RigidBody2D

@export var fuse_time: float = 2.0 # Waktu sebelum meledak
@export var explosion_damage: int = 30
@export var explosion_force: float = 100.0

@onready var explosion_area = $Area2D

func _ready():
	get_tree().create_timer(fuse_time).timeout.connect(explode)

func launch(initial_velocity: Vector2):
	linear_velocity = initial_velocity

func explode():
	var bodies = explosion_area.get_overlapping_bodies()
	
	for body in bodies:
		if body.is_in_group(\"Player\"):
			if body.has_method(\"take_damage\"):
				body.take_damage(explosion_damage)
			
			var direction = (body.global_position - global_position).normalized()
			if body is CharacterBody2D:
				body.velocity += direction * explosion_force
	print(\"DUARRR\")
	queue_free()
"

